{
  "name": "@pastapastapasta/platform-auth",
  "version": "0.1.0",
  "description": "Reusable Dash Platform authentication orchestration for web apps.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PastaPastaPasta/platform-auth.git"
  },
  "bugs": {
    "url": "https://github.com/PastaPastaPasta/platform-auth/issues"
  },
  "homepage": "https://github.com/PastaPastaPasta/platform-auth#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "keywords": [
    "dash",
    "platform",
    "auth",
    "react",
    "webauthn",
    "passkey"
  ],
  "author": "Codex",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^3.0.0",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  }
}
